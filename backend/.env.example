# Server Configuration
PORT=5000
NODE_ENV=development

# Database cloud
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/medilink?retryWrites=true&w=majority
#OR
# Database local
MONGODB_URI=mongodb://localhost:27017/medilink

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRE=7d

# Firebase Admin SDK (Download from Firebase Console)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# Email Configuration (Gmail SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password

# Frontend URL (CORS)
CLIENT_URL=http://localhost:3000

GOOGLE_PLACES_API_KEY=google_map_api
